{
  "name": "breakpoint",
  "version": "0.2.1",
  "author": "Xinyi Zhang",
  "description": "Tennis highlight extraction desktop app",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "test:renderer-flow": "node scripts/renderer-flow.test.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --config electron-builder.yml --win",
    "package:msi": "python scripts/package.py"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.breakpoint.app",
    "productName": "Breakpoint",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
